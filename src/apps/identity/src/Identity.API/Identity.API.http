# Identity API — Flujo completo Authorization Code + PKCE
@host = http://localhost:5000

# ── Variables del flujo ────────────────────────────────────
@client_id = portal
@redirect_uri = http://localhost:3002/api/auth/callback
@code_verifier = 0MugUPSbkW4r3Hm_w9CVOyON43UJuKmJIDVWSIo1JuI
@code_challenge = GAuNz_WkCWdkigQtmjbcxheYZ0Tm9hx1GKO8MGUYelg
@client_secret = portal-secret-change-me

# ════════════════════════════════════════════════════════════
# PASO 0 — Verificar que el servidor responde
# ════════════════════════════════════════════════════════════

### Health check
GET {{host}}/health

###

### Discovery Document — verifica endpoints disponibles
GET {{host}}/.well-known/openid-configuration

###

### JWKS — clave pública RSA
GET {{host}}/.well-known/jwks.json

###

# ════════════════════════════════════════════════════════════
# PASO 1 — Login del usuario
# El frontend llama a este endpoint con las credenciales
# ════════════════════════════════════════════════════════════

### POST /auth/login
# @name loginResponse
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "admin@localhost.com",
  "password": "Admin1234!",
  "clientId": "{{client_id}}",
  "redirectUri": "{{redirect_uri}}",
  "codeChallenge": "{{code_challenge}}",
  "codeChallengeMethod": "S256",
  "state": "random-state-abc123"
}

###

# ════════════════════════════════════════════════════════════
# PASO 2 — Intercambiar el code por tokens
# Copia el "code" de la respuesta del PASO 1 aquí abajo
# ════════════════════════════════════════════════════════════

### POST /oauth/token — authorization_code
# Reemplaza CODE_AQUI con el valor recibido en el paso 1
@authorization_code = N2O0pT6KM1fdXzGgPXlIc6buc5463HPzQ9U2LjH7ObA

POST {{host}}/oauth/token
Content-Type: application/x-www-form-urlencoded

grant_type=authorization_code&code={{authorization_code}}&code_verifier={{code_verifier}}&client_id={{client_id}}&client_secret={{client_secret}}&redirect_uri={{redirect_uri}}

###

# ════════════════════════════════════════════════════════════
# PASO 3 — Renovar el access token con refresh token
# Copia el "refreshToken" de la respuesta del PASO 2
# ════════════════════════════════════════════════════════════

### POST /oauth/token — refresh_token
@refresh_token = _MTQPZy4Hww2Q2o_W7U9pubuPKsbINmogp86owyOG8c

POST {{host}}/oauth/token
Content-Type: application/x-www-form-urlencoded

grant_type=refresh_token&refresh_token={{refresh_token}}&client_id={{client_id}}&client_secret={{client_secret}}

###

# ════════════════════════════════════════════════════════════
# PASO 4 — Revocar el refresh token (logout)
# ════════════════════════════════════════════════════════════

### POST /oauth/revoke
POST {{host}}/oauth/revoke
Content-Type: application/x-www-form-urlencoded

token={{refresh_token}}&token_type_hint=refresh_token&client_id={{client_id}}&client_secret={{client_secret}}

